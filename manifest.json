{
	"manifest_version": 2,
	"name": "外部网址跳转直接打开",
	"version": "1.0.0",
	"description": "支持简书，知乎网页直接打开外部网址",
	"icons":
	{
		"16": "img/icon.png",
		"48": "img/icon.png",
		"128": "img/icon.png"
	},
	// "background":
	// {
	// 	"page": "background.html",
	// 	"scripts": ["js/background.js"]
	// },
	"browser_action": 
	{
		"default_icon": "img/icon.png",
		// "default_title": "",
		"default_popup": "popup.html"
	},
	"content_scripts": 
	[
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["js/jquery.min.js", "js/content-script.js"],
			"css": ["css/custom.css"],
			"run_at": "document_end"
		}
	],
	"permissions":
	[
		"webRequest", // web请求
		"webRequestBlocking",
		"storage", // 插件本地存储
		"http://*/*", // 可以通过executeScript或者insertCSS访问的网站
		"https://*/*" // 可以通过executeScript或者insertCSS访问的网站
	],
	"homepage_url": "https://www.baidu.com",
	// Chrome40以前的插件配置页写法
	"options_page": "options.html",
	// Chrome40以后的插件配置页写法，如果2个都写，新版Chrome只认后面这一个
	"options_ui":
	{
		"page": "options.html",
		// 添加一些默认的样式，推荐使用
		"chrome_style": true
	}
}